{
  "usesTypeScript": false,
  "usesStyledComponents": false,
  "usesCssModule": true,
  "cssPreprocessor": "css",
  "testLibrary": "None",
  "component": {
    "default": {
      "customTemplates": {
        "component": "./templates/components-templates/TemplateName.jsx"
      },
      "path": "src/components",
      "withStyle": true,
      "withTest": false,
      "withStory": false,
      "withLazy": false
    },
    "page": {
      "path": "src/pages",
      "withLazy": false,
      "withStory": false,
      "withStyle": true,
      "withTest": false,
      "customTemplates": {
        "component": "./templates/pages-templates/TemplateName.jsx"
      }
    },
    "layout": {
      "path": "src/layouts",
      "withStyle": false,
      "withLazy": false,
      "withStory": false,
      "withTest": false,
      "customTemplates": {
        "component": "./templates/layouts-templates/LayoutTemplate.jsx"
      }
    }
  }
}
